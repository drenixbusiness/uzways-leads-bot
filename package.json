{
  "name": "leads-daily-bot",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "start": "node index.js",
    "report": "node index.js --report",
    "report:yesterday": "node index.js --report --yesterday",
    "pm2:start": "npx pm2 start ecosystem.config.cjs",
    "pm2:stop": "npx pm2 stop ecosystem.config.cjs",
    "pm2:restart": "npx pm2 restart ecosystem.config.cjs",
    "pm2:save": "npx pm2 save",
    "deploy:linux": "bash deploy.sh",
    "deploy:windows": "powershell -ExecutionPolicy Bypass -File deploy.ps1",
    "pm2:install-service": "npx pm2-service-install --startup-start-mode auto"
  },
  "dependencies": {
    "dotenv": "^16.4.7",
    "luxon": "^3.5.0",
    "node-cron": "^3.0.3"
  },
  "devDependencies": {
    "pm2": "^5.3.0"
  }
}
